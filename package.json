{
  "name": "nexo-desktop",
  "version": "1.4.0",
  "description": "Nexo desktop app built with Electron",
  "main": "main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win nsis",
    "release": "node scripts/release.js",
    "selfcheck:exports": "node scripts/selfcheck-exports.js"
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "png2icons": "^2.0.1"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.3.9",
    "xlsx-js-style": "^1.2.0"
  },
  "build": {
    "appId": "com.nexo.desktop",
    "productName": "Nexo",
    "artifactName": "${productName}-${version}.${ext}",
    "files": [
      "main.js",
      "update-manager.js",
      "preload.js",
      "renderer/**/*",
      "Nexo Logo.png",
      "nexo.ico"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "zhinouno-ui",
        "repo": "nexo-desktop",
        "channel": "latest"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "nexo.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
